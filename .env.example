POSTGRES_DB=urban_service
POSTGRES_USER=urban_user
POSTGRES_PASSWORD=urban_password
POSTGRES_PORT=5433

# Comma-separated frontend origins that the Spring Boot backend allows.
# Local defaults work for Vite dev server and Docker frontend.
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional backend port override.
# Local Spring Boot defaults to 8080 if this is empty.
PORT=8080

# Used by the Vite frontend at build time.
# Leave empty locally so the frontend calls relative /api URLs.
# In cloud deployment, set this to the deployed backend URL.
VITE_API_BASE_URL=
